# Environment Configuration
# Kopiere diese Datei zu .env und fülle die Werte aus

# Application
NODE_ENV=development
LOG_LEVEL=info

# Dokumenten-Verarbeitung
SOURCE_DOCUMENTS_PATH=./source-documents
EXTRACTION_RULES_PATH=./extraction-rules
RESULTS_PATH=./results
LEARNING_PATH=./learning

# Extraktion
MIN_CONFIDENCE_THRESHOLD=0.8
MAX_CHUNK_SIZE=5000
ENABLE_AUDIT_TRAIL=true

# Datenbank (optional für zukünftige Versionen)
# DATABASE_URL=postgresql://user:password@localhost:5432/extractor

# Logging
LOG_FORMAT=json
ENABLE_FILE_LOGGING=true
LOG_FILE_PATH=./logs

# Testing
TEST_TIMEOUT_MS=10000
ENABLE_COVERAGE_REPORTS=true
