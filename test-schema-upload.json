{
  "schema": {
    "type": "object",
    "properties": {
      "invoiceNumber": {
        "type": "string",
        "pattern": "^INV-\\d{6}$"
      },
      "amount": {
        "type": "number"
      },
      "date": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "vendor": {
        "type": "string"
      }
    },
    "required": ["invoiceNumber", "amount", "date"]
  },
  "examples": [
    {
      "invoiceNumber": "INV-001234",
      "amount": 1299.50,
      "date": "2026-07-08",
      "vendor": "ABC Corp"
    },
    {
      "invoiceNumber": "INV-001235",
      "amount": 2500.00,
      "date": "2026-07-07",
      "vendor": "XYZ Inc"
    },
    {
      "invoiceNumber": "INV-001236",
      "amount": 750.25,
      "date": "2026-07-06",
      "vendor": "Tech Solutions"
    }
  ],
  "name": "Invoice Schema",
  "aggressiveness": 0.7
}
