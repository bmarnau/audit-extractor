{
    "title":  "Invoice",
    "properties":  {
                       "customerName":  {
                                            "type":  "string",
                                            "description":  "Customer full name"
                                        },
                       "currency":  {
                                        "enum":  [
                                                     "EUR",
                                                     "USD",
                                                     "GBP"
                                                 ],
                                        "description":  "Currency code",
                                        "type":  "string"
                                    },
                       "totalAmount":  {
                                           "type":  "number",
                                           "description":  "Total invoice amount"
                                       },
                       "invoiceDate":  {
                                           "format":  "date",
                                           "description":  "Date of invoice",
                                           "type":  "string"
                                       },
                       "invoiceNumber":  {
                                             "type":  "string",
                                             "description":  "Unique invoice identifier"
                                         }
                   },
    "$schema":  "http://json-schema.org/draft-07/schema#",
    "type":  "object",
    "required":  [
                     "invoiceNumber",
                     "customerName",
                     "totalAmount"
                 ]
}
