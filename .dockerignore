# Node modules (rebuild in container, ~150MB savings)
node_modules/
*/node_modules/
**/node_modules/
npm-debug.log
yarn-error.log

# Build artifacts (rebuild in container)
dist/
build/
coverage/
frontend/dist/
frontend/build/
**/.next/
**/out/

# Environment (use Docker env)
.env
.env.local
.env.*.local
.env*.example

# IDE (not needed)
.vscode/
.idea/
*.sublime-*
*.swp
*.swo
*.iml

# OS
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# Keep documentation - needed by backend for help content!
# /docs is needed
# MANUAL*.md is needed for help center
# All .md files in root are needed

# Test & temporary files
*.test.ts
*.spec.ts
__tests__/
.jest/
.testing-library/
temp/
tmp/

# Docker (avoid recursion)
Dockerfile*
docker-compose*.yml
.docker/

# Logs
logs/
*.log*

# Other
.browserslistrc
.eslintrc*
.prettierrc*
.editorconfig
jest.config.js
playwright.config.ts
