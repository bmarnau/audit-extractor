# Docker Environment Configuration
# Kopieren Sie diese Datei zu .env.docker und passen Sie nach Bedarf an

# ============================================================
# Backend Service
# ============================================================

# Node Environment
NODE_ENV=production

# Server
PORT=3000
API_URL=http://backend:3000/api
CORS_ORIGIN=http://localhost:5173,http://localhost,http://127.0.0.1

# Logging
LOG_LEVEL=info

# ============================================================
# Database (PostgreSQL)
# ============================================================

# Connection String
DATABASE_URL=postgresql://extractor_user:extractor_pass@postgres:5432/extractor_db

# Alternative einzelne Parameter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=extractor_user
POSTGRES_PASSWORD=extractor_pass
POSTGRES_DB=extractor_db

# ============================================================
# Cache (Redis)
# ============================================================

REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================
# Optional: LLM/AI Services (für zukünftige Phasen)
# ============================================================

# LLM_PROVIDER=azure-openai
# LLM_API_KEY=your-api-key-here
# LLM_MODEL=gpt-4-turbo
# AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/

# ============================================================
# Frontend
# ============================================================

# Frontend wird mit Nginx über Port 80 serviert
# API-Proxy wird in nginx.conf konfiguriert

# ============================================================
# Development/Production Konfiguration
# ============================================================

# Für lokale Entwicklung mit Docker:
# - NODE_ENV=development
# - LOG_LEVEL=debug
# - API_URL=http://localhost:3000/api
# - CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Für Production:
# - NODE_ENV=production
# - LOG_LEVEL=warn
# - DATABASE_URL mit sicherem Password
# - CORS_ORIGIN auf erlaubte Domains setzen
