{
  "name": "audit-safe-document-extractor",
  "version": "0.24.0",
  "description": "Document Preparation Pipeline (Phase 23.0: Complete + Phase 24 Planning: Extended Adapters & Services)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "build:watch": "tsc --watch",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:unit": "jest --testMatch='**/tests/unit/**/*.test.ts'",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api:14a": "node scripts/test-extraction-api.js",
    "test:api:14b": "node scripts/test-phase14b-api.js",
    "test:api:14c": "node scripts/test-phase14c-api.js",
    "test:api:14-e2e": "node scripts/test-phase14-e2e.js",
    "test:all": "npm run test:api:14a && npm run test:api:14b && npm run test:api:14c && npm run test:api:14-e2e",
    "test:phase16:e2e": "ts-node tests/phase16-e2e-test.ts",
    "test:phase16:audit": "ts-node tests/audit-workflow-integration.ts",
    "test:phase16:all": "npm run test:phase16:e2e && npm run test:phase16:audit",
    "test:e2e:frontend": "playwright test tests/e2e/comprehensive-frontend-test.spec.ts",
    "test:analyze:startup": "pwsh scripts/analyze-docker-startup.ps1",
    "test:stability:100": "pwsh scripts/stability-test-100-cycles.ps1 -Cycles 100",
    "test:stability:10": "pwsh scripts/stability-test-100-cycles.ps1 -Cycles 10",
    "test:all:comprehensive": "pwsh scripts/run-all-tests.ps1",
    "job:execute": "ts-node -r tsconfig-paths/register src/cli/execute-job.ts",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"docs/**/*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"docs/**/*.md\"",
    "validate": "npm run lint && npm run test:coverage && npm run build",
    "prepare": "husky install"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "cheerio": "^1.0.0-rc.12",
    "express": "^4.18.2",
    "form-data": "^4.0.6",
    "mammoth": "^1.6.0",
    "multer": "^2.2.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "reflect-metadata": "^0.1.13",
    "tsyringe": "^4.8.0",
    "typeorm": "^0.3.19",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "pdfkit": "^0.19.1",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tsc-alias": "^1.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
