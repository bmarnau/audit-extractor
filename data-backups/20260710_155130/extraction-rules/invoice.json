  "owner": "finance-team",
  "rules": [
    {
      "field": "invoiceNumber",
      "pattern": "(INV-[0-9]{6}|Invoice #[0-9]{4}-[0-9]{2}|Rechnungsnummer[:\\s]+([A-Z0-9-]+))",
      "confidence": 0.92,
      "required": true,
      "description": "Eindeutige Rechnungsnummer (z.B. INV-202406-0142)"
    },
    {
      "field": "invoiceDate",
      "pattern": "(?:Datum|Rechnungsdatum|Date)[:\\s]+([0-3]?[0-9]\\.[0-1]?[0-9]\\.\\d{4})",
      "confidence": 0.95,
      "required": true,
      "description": "Ausstellungsdatum (Format: DD.MM.YYYY)"
    },
    {
      "field": "customerName",
      "pattern": "(?:Kundennamen|Customer Name|An|Bill To)[:\\s]+([A-Z][^\\n]+(?:GmbH|AG|KG|Ltd|Inc)?)",
      "confidence": 0.88,
      "required": true,
      "description": "Name des Kunden/Rechnungsempfänger"
    },
    {
      "field": "customerAddress",
      "pattern": "(?:Adresse|Address|Straße|Street)[:\\s]+([^\\n]+(?:,\\s*[^\\n]+)?)",
      "confidence": 0.80,
      "required": false,
      "description": "Adresse des Kunden"
    },
    {
      "field": "totalAmount",
      "pattern": "(?:Gesamtbetrag|Total Amount|Summe|Gesamtsumme)[:\\s]+([0-9]{1,3}(?:\\.[0-9]{3})*(?:,\\d{2})?)",
      "confidence": 0.91,
      "required": true,
      "description": "Gesamtbetrag der Rechnung (mit oder ohne Tausender-Trennzeichen)"
    },
    {
      "field": "taxAmount",
      "pattern": "(?:Steuer|USt|MwSt|Tax|VAT)[:\\s]+([0-9]{1,3}(?:\\.[0-9]{3})*(?:,\\d{2})?)",
      "confidence": 0.87,
      "required": false,
      "description": "Steuerbetrag/MwSt"
    },
    {
      "field": "dueDate",
      "pattern": "(?:Zahlbar bis|Due Date|Fälligkeit|Zahlungsfrist)[:\\s]+([0-3]?[0-9]\\.[0-1]?[0-9]\\.\\d{4})",
      "confidence": 0.75,
      "required": false,
      "description": "Zahlungsfälligkeitsdatum"
    },
    {
      "field": "paymentTerms",
      "pattern": "(?:Zahlungsbedingungen|Payment Terms|Bedingungen)[:\\s]+([^\\n]+)",
      "confidence": 0.70,
      "required": false,
      "description": "Zahlungsbedingungen (z.B. NET30)"
    }
  ],
