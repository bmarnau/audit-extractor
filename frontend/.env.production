# Frontend Environment - Production
VITE_API_URL=https://api.audit-extractor.app/api
VITE_LOG_LEVEL=warn
VITE_ENABLE_TRACING=false

# React App API Configuration (configure before deployment)
REACT_APP_API_URL=https://api.audit-extractor.app
REACT_APP_ENV=production

# Feature Flags
REACT_APP_ENABLE_LEARNING=true
REACT_APP_ENABLE_BATCH_OPERATIONS=true
