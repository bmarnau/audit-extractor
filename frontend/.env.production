# Frontend Environment - Production
# ⚠️ IMPORTANT: Vite uses VITE_ prefix, NOT REACT_APP_
# v0.37.1: Use relative URL /api for Docker Nginx reverse proxy
VITE_API_URL=/api
VITE_LOG_LEVEL=warn
VITE_ENABLE_TRACING=false
VITE_APP_VERSION=0.37.1

# Feature Flags
VITE_ENABLE_LEARNING=true
VITE_ENABLE_BATCH_OPERATIONS=true
