# Frontend Environment - Development
# ⚠️ IMPORTANT: Vite uses VITE_ prefix, NOT process.env
# All variables here are injected at build time via import.meta.env

# API Configuration (used by Vite)
VITE_API_URL=http://localhost:3000
VITE_LOG_SERVER=http://localhost:3000/api/logs
VITE_LOG_LEVEL=debug
VITE_ENABLE_TRACING=true

# Feature Flags (used by Vite)
VITE_ENABLE_LEARNING=true
VITE_ENABLE_BATCH_OPERATIONS=true
